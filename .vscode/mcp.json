{
  "servers": {
    "interactive-opentui-mcp": {
      "command": "bun",
      "args": [
        "run",
        "dist/index.js",
        "-t",
        "800",
        "--disable-tools",
        "message_complete_notification",
        "--tui-renderer",
        "opentui"
      ],
      "timeout": 800000,
      "type": "stdio"
    },
    "interactive-desktop": {
      "url": "http://localhost:3100/sse",
      "type": "sse",
      "timeout": 1210000
    }
  }
}
