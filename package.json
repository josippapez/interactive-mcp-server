    "@opentui/react": "^0.1.86",
    "@types/yargs": "^17.0.33",
    "node-notifier": "^10.0.1",
    "pino": "^9.6.0",
    "react": "^19.2.0",
    "yargs": "^17.7.2",
    "zod": "^3.24.3"
