{
  "name": "@rawwee/interactive-mcp",
  "version": "1.5.5",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "interactive-mcp": "dist/index.js"
  },
  "files": [
    "dist/constants.js",
    "dist/index.js",
    "dist/commands/input",
    "dist/commands/intensive-chat",
    "dist/components",
    "dist/tool-definitions",
    "dist/utils",
    "README.md",
    "LICENSE",
    "package.json"
  ],
  "scripts": {
    "build": "tsc --outDir dist && tsc-alias",
    "start": "bun dist/index.js",
    "lint": "eslint \"src/**/*.{js,ts,jsx,tsx}\"",
    "format": "prettier --write \"src/**/*.{js,ts,jsx,tsx,json,md}\"",
    "check-types": "tsc --noEmit",
    "prepare": "husky"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "description": "",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/josippapez/interactive-mcp-server.git"
  },
  "homepage": "https://github.com/josippapez/interactive-mcp-server#readme",
  "bugs": {
    "url": "https://github.com/josippapez/interactive-mcp-server/issues"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "@types/bun": "^1.3.10",
    "@types/node": "^25.3.5",
    "@types/node-notifier": "^8.0.5",
    "@types/pino": "^7.0.5",
    "@types/react": "^19.2.14",
    "conventional-changelog-conventionalcommits": "^9.3.0",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "jiti": "^2.6.1",
    "lint-staged": "^16.3.2",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.1",
    "semantic-release": "^25.0.3",
    "tsc-alias": "^1.8.16",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@opentui/core": "0.1.87",
    "@opentui/react": "0.1.87",
    "@types/yargs": "^17.0.35",
    "node-notifier": "^10.0.1",
    "pino": "^10.3.1",
    "react": "^19.2.4",
    "yargs": "^18.0.0",
    "zod": "^4.3.6"
  },
  "lint-staged": {
    "*.{js,ts,jsx,tsx}": [
      "eslint --fix"
    ],
    "*.{js,ts,jsx,tsx,json,md}": [
      "prettier --write"
    ]
  },
  "packageManager": "bun@1.3.10"
}
